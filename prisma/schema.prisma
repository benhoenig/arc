// ARC Prisma schema — hand-written to match the SQL migration because
// `prisma db pull` hangs on Supabase free-tier networking (IPv4 + pooler
// transaction mode). Once on Pro tier with IPv4 direct, re-run db pull
// to verify this file matches the DB exactly.
//
// Source of truth: supabase/migrations (applied via MCP). Per CONVENTIONS.md
// §5.2, SQL migrations own the schema; this file is regenerated from them.
//
// Prisma 7: connection URLs live in prisma.config.ts, not here. Runtime
// uses a driver adapter in src/server/db.ts.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Foundation tables (M1)
// ============================================

model Organization {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  slug                  String    @unique
  countryCode           String    @default("TH") @map("country_code") @db.Char(2)
  currency              String    @default("THB") @db.Char(3)
  timezone              String    @default("Asia/Bangkok")
  stripeCustomerId      String?   @unique @map("stripe_customer_id")
  subscriptionStatus    String?   @map("subscription_status")
  subscriptionPlan      String?   @map("subscription_plan")
  subscriptionStartedAt DateTime? @map("subscription_started_at") @db.Timestamptz(6)
  settings              Json      @default("{}")
  metadata              Json      @default("{}")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz(6)

  roles        Role[]
  userRoles    UserRole[]
  activityLog  ActivityLog[]
  featureFlags FeatureFlag[]
  flipStages   FlipStage[]
  properties   Property[]
  dealAnalyses DealAnalysis[]
  contacts     Contact[]
  projects     Project[]

  @@map("organizations")
}

model User {
  id          String    @id @db.Uuid
  email       String    @unique
  fullName    String?   @map("full_name")
  displayName String?   @map("display_name")
  avatarUrl   String?   @map("avatar_url")
  phone       String?
  lineUserId  String?   @map("line_user_id")
  locale      String    @default("th")
  lastSeenAt  DateTime? @map("last_seen_at") @db.Timestamptz(6)
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  userRoles               UserRole[]     @relation("UserToUserRole")
  createdRoles            UserRole[]     @relation("UserRoleCreatedBy")
  activityLog             ActivityLog[]
  propertiesCreated       Property[]     @relation("PropertyCreatedBy")
  propertiesUpdated       Property[]     @relation("PropertyUpdatedBy")
  dealAnalysesDecided     DealAnalysis[] @relation("DealAnalysisDecidedBy")
  dealAnalysesCreated     DealAnalysis[] @relation("DealAnalysisCreatedBy")
  dealAnalysesUpdated     DealAnalysis[] @relation("DealAnalysisUpdatedBy")

  @@map("users")
}

model Role {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  slug           String
  nameTh         String    @map("name_th")
  nameEn         String?   @map("name_en")
  descriptionTh  String?   @map("description_th")
  descriptionEn  String?   @map("description_en")
  permissions    Json      @default("{}")
  isSystem       Boolean   @default(false) @map("is_system")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userRoles    UserRole[]

  @@unique([organizationId, slug], map: "idx_roles_org_slug")
  @@index([organizationId], map: "idx_roles_org")
  @@map("roles")
}

model UserRole {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  roleId         String    @map("role_id") @db.Uuid
  flipId         String?   @map("flip_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy      String?   @map("created_by") @db.Uuid
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("UserToUserRole", fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdByUser User?       @relation("UserRoleCreatedBy", fields: [createdBy], references: [id])

  @@index([userId], map: "idx_user_roles_user")
  @@index([organizationId], map: "idx_user_roles_org")
  @@map("user_roles")
}

model ActivityLog {
  id             BigInt   @id @default(autoincrement())
  organizationId String   @map("organization_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id") @db.Uuid
  action         String
  changes        Json?
  context        Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt(sort: Desc)], map: "idx_activity_entity")
  @@index([organizationId, createdAt(sort: Desc)], map: "idx_activity_org")
  @@index([userId, createdAt(sort: Desc)], map: "idx_activity_user")
  @@map("activity_log")
}

model FeatureFlag {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  flagKey        String    @map("flag_key")
  isEnabled      Boolean   @default(false) @map("is_enabled")
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, flagKey])
  @@index([organizationId, flagKey, isEnabled], map: "idx_feature_flags_lookup")
  @@map("feature_flags")
}

// ============================================
// M2: Properties & Deal Analysis
// ============================================

model FlipStage {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  slug           String
  nameTh         String    @map("name_th")
  nameEn         String?   @map("name_en")
  sortOrder      Int       @default(0) @map("sort_order")
  stageType      String    @map("stage_type")
  isSystem       Boolean   @default(false) @map("is_system")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug], map: "idx_flip_stages_org_slug")
  @@index([organizationId, sortOrder], map: "idx_flip_stages_org")
  @@map("flip_stages")
}

model Contact {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  contactType    String    @default("agent") @map("contact_type")
  phone          String?
  lineId         String?   @map("line_id")
  email          String?
  notes          String?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  properties   Property[]

  @@index([organizationId], map: "idx_contacts_org")
  @@map("contacts")
}

model Project {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  developer      String?
  location       String?
  propertyType   String?   @map("property_type")
  notes          String?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  properties   Property[]

  @@unique([organizationId, name], map: "idx_projects_org_name")
  @@index([organizationId], map: "idx_projects_org")
  @@map("projects")
}

model Property {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid

  // Identification
  listingName    String    @map("listing_name")
  projectId      String?   @map("project_id") @db.Uuid
  contactId      String?   @map("contact_id") @db.Uuid
  listingUrl     String?   @map("listing_url")

  // Address (optional — hidden from default form, kept for future map features)
  addressLine1   String?   @map("address_line1")
  addressLine2   String?   @map("address_line2")
  subdistrict    String?
  district       String?
  province       String?
  postalCode     String?   @map("postal_code")
  countryCode    String    @default("TH") @map("country_code") @db.Char(2)
  latitude       Decimal?  @db.Decimal(10, 7)
  longitude      Decimal?  @db.Decimal(10, 7)

  // Legal
  titleDeedNumber String?  @map("title_deed_number")
  titleDeedType   String?  @map("title_deed_type")
  landAreaSqwa    Decimal? @map("land_area_sqwa") @db.Decimal(10, 2)
  landAreaSqm     Decimal? @map("land_area_sqm") @db.Decimal(10, 2)

  // Physical
  propertyType   String    @map("property_type")
  bedrooms       Int?
  bathrooms      Decimal?  @db.Decimal(4, 1)
  floorAreaSqm   Decimal?  @map("floor_area_sqm") @db.Decimal(10, 2)
  yearBuilt      Int?      @map("year_built")
  floors         Int?
  floorLevel     Int?      @map("floor_level")

  // Pricing
  askingPriceThb Decimal?  @map("asking_price_thb") @db.Decimal(14, 2)
  priceRemark    String?   @map("price_remark")

  // Pipeline
  sourcingStatus String    @default("new") @map("sourcing_status")

  notes          String?
  metadata       Json      @default("{}")

  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contact        Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdByUser  User?          @relation("PropertyCreatedBy", fields: [createdBy], references: [id])
  updatedByUser  User?          @relation("PropertyUpdatedBy", fields: [updatedBy], references: [id])
  dealAnalyses   DealAnalysis[]

  @@index([organizationId], map: "idx_properties_org")
  @@index([province, district], map: "idx_properties_location")
  @@index([projectId], map: "idx_properties_project")
  @@index([contactId], map: "idx_properties_contact")
  @@index([organizationId, sourcingStatus], map: "idx_properties_status")
  @@map("properties")
}

model DealAnalysis {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId          String    @map("organization_id") @db.Uuid
  propertyId              String    @map("property_id") @db.Uuid
  flipId                  String?   @map("flip_id") @db.Uuid

  flipType                String    @default("float_flip") @map("flip_type")
  label                   String?   @db.VarChar(100)

  // Shared fields (both types)
  estPurchasePriceThb     Decimal   @map("est_purchase_price_thb") @db.Decimal(14, 2)
  estRenovationCostThb    Decimal   @map("est_renovation_cost_thb") @db.Decimal(14, 2)
  estSellingCostThb       Decimal   @default(0) @map("est_selling_cost_thb") @db.Decimal(14, 2)
  estArvThb               Decimal   @map("est_arv_thb") @db.Decimal(14, 2)
  estTimelineDays         Int       @map("est_timeline_days")

  // Transfer-in specific
  estHoldingCostThb       Decimal   @default(0) @map("est_holding_cost_thb") @db.Decimal(14, 2)
  estTransactionCostThb   Decimal   @default(0) @map("est_transaction_cost_thb") @db.Decimal(14, 2)

  // Float-flip specific
  depositAmountThb        Decimal?  @map("deposit_amount_thb") @db.Decimal(14, 2)
  contractMonths          Int?      @map("contract_months")
  marketingCostThb        Decimal   @default(0) @map("marketing_cost_thb") @db.Decimal(14, 2)

  // Both types
  otherCostThb            Decimal   @default(0) @map("other_cost_thb") @db.Decimal(14, 2)

  // Computed (stored for snapshot integrity)
  totalCostThb            Decimal   @map("total_cost_thb") @db.Decimal(14, 2)
  estProfitThb            Decimal   @map("est_profit_thb") @db.Decimal(14, 2)
  estMarginPct            Decimal   @map("est_margin_pct") @db.Decimal(6, 2)
  estRoiPct               Decimal   @map("est_roi_pct") @db.Decimal(6, 2)

  decision                String?
  decisionNotes           String?   @map("decision_notes")
  decidedAt               DateTime? @map("decided_at") @db.Timestamptz(6)
  decidedBy               String?   @map("decided_by") @db.Uuid

  notes                   String?
  metadata                Json      @default("{}")

  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy               String?   @map("created_by") @db.Uuid
  updatedBy               String?   @map("updated_by") @db.Uuid
  deletedAt               DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  decidedByUser  User?        @relation("DealAnalysisDecidedBy", fields: [decidedBy], references: [id])
  createdByUser  User?        @relation("DealAnalysisCreatedBy", fields: [createdBy], references: [id])
  updatedByUser  User?        @relation("DealAnalysisUpdatedBy", fields: [updatedBy], references: [id])

  @@index([propertyId], map: "idx_deal_analyses_property")
  @@index([flipId], map: "idx_deal_analyses_flip")
  @@index([organizationId], map: "idx_deal_analyses_org_pending")
  @@map("deal_analyses")
}
