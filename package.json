{
  "name": "arc",
  "version": "0.1.0",
  "private": true,
  "description": "ARC — property flipping management system for Thai small-team operations",
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
