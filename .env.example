# ARC environment variables
# Copy to `.env.local` and fill in real values.
# Validated at boot by src/lib/env.ts — missing vars crash the app with a clear error.

# Public app URL — the canonical origin the app serves from.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — Singapore project (ap-southeast-1). See docs/TECH_STACK.md §13.2.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct (unpooled) connection — for Prisma migrations only.
SUPABASE_DB_URL=
# Supavisor pooled connection (transaction mode) — for runtime queries.
SUPABASE_DB_URL_POOLED=

# LINE Notify — v1 notification channel. v2 migrates to LINE Messaging API.
LINE_NOTIFY_CLIENT_ID=
LINE_NOTIFY_CLIENT_SECRET=

# Trigger.dev — background jobs per docs/TECH_STACK.md §10.1.
TRIGGER_API_KEY=
TRIGGER_API_URL=https://api.trigger.dev

# Sentry — optional; enable in v1.5+ per docs/TECH_STACK.md §13.
SENTRY_DSN=
